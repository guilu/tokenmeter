# TokenMeter Docker host bindings.
# Use 127.0.0.1 when Nginx runs on the same host.
# If Nginx, Prometheus or Grafana run on another machine, use the Docker host
# private IP or 0.0.0.0 and restrict access with firewall/security groups.
TOKENMETER_BIND_ADDRESS=127.0.0.1
TOKENMETER_FRONTEND_PORT=3001
TOKENMETER_BACKEND_PORT=8081

# PostgreSQL is internal-only: it is not published on the host.
TOKENMETER_DB_NAME=tokenmeter
TOKENMETER_DB_USER=tokenmeter
TOKENMETER_DB_PASSWORD=change-me

# Backend repository intake
TOKENMETER_WORKDIR=/tmp/tokenmeter-repositories
TOKENMETER_MAX_REPOSITORY_BYTES=314572800
TOKENMETER_CLONE_TIMEOUT=120s
